// CREATING DATABASE 
 CREATE DATABASE COMPANY2CSE2;

 //Using Database
 USE COMPANY2CSE2;

 //Creating table Department
 CREATE TABLE DEPARTMENT(
    ->     DEPTNO INT(2) PRIMARY KEY,
    ->     DNAME VARCHAR(15) NOT NULL
    -> );
// Creating Table Employee
 CREATE TABLE EMPLOYEE(
    -> EMPNO INT(4) PRIMARY KEY,
    -> ENAME VARCHAR(2) NOT NULL,
    -> JOB VARCHAR(20) ,
    -> MGR INT(4),
    -> HIREDATE DATE,
    -> SAL INT(10),
    -> COMM INT(7),
    -> DEPTNO INT(2),
    -> FOREIGN KEY(DEPTNO) REFERENCES DEPARTMENT(DEPTNO)
    -> );

// Showing All the Values Of the table

SELECT * FROM EMPLOYEE;

//1. Create EMPLOYEE_MASTER Table Using EMPLOYEE Table

 CREATE TABLE EMPLOYEE_MASTER SELECT * FROM EMPLOYEE;
 SELECT * FROM EMPLOYEE_MASTER;
 DESC EMPLOYEE_MASTER;

 //2.Delete all the record of Employee_master where deptno is 10

 DELETE FROM EMPLOYEE_MASTER WHERE DEPTNO = 10;
 SELECT * FROM EMPLOYEE_MASTER;

//3.Update 10% sal of DEPTNO 20 into Employee_master

 UPDATE EMPLOYEE_MATER SET SAL = SAL+SAL*0.1 WHERE DEPTNO=20;
 SELECT * FROM EMPLOYEE_MASTER;

//4.Alter sal with size 10,2 in Employee_master.

ALTER TABLE EMPLOYEE_MASTER MODIFY SAL DECIMAL(10,2);
SELECT * FROM EMPLOYEE_MASTER;

//5.Drop Employee_master table;

 DROP TABLE EMPLOYEE_MASTER;
 SELECT * FROM EMPLOYEE_MASTER; 
